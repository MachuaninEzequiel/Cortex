# Cortex Pi — Justfile
# Carga automáticamente el .env si existe en el directorio actual.
# Uso: just <recipe>
#
# Requiere: just, pi v0.70+
# Instalar just: https://just.systems/  (o: winget install Casey.Just)

set dotenv-load := true
set shell := ["powershell", "-Command"]

EXT := ".pi/extensions"

# ── Listado de recipes ────────────────────────────────────────────────────
# Muestra todos los comandos disponibles
default:
    @just --list

# ── Pi base ───────────────────────────────────────────────────────────────
# Pi sin extensiones adicionales (usa solo lo que carga settings.json)
pi:
    pi

# ── Selector de agente (/system) ─────────────────────────────────────────
system-select:
    pi -e {{EXT}}/system-select.ts

# ── Pipeline de agentes (/chain) ─────────────────────────────────────────
agent-chain:
    pi -e {{EXT}}/agent-chain.ts

# ── Damage control (seguridad) ───────────────────────────────────────────
damage-control:
    pi -e {{EXT}}/damage-control.ts

# ── MCP server de Cortex ─────────────────────────────────────────────────
# Levanta el servidor MCP y expone sus tools como mcp_cortex_mcp_*
mcp:
    pi -e {{EXT}}/cortex-mcp.ts

# ── Stack completo Cortex ─────────────────────────────────────────────────
# Las cuatro extensiones juntas: selector + pipeline + seguridad + MCP
cortex:
    pi -e {{EXT}}/system-select.ts -e {{EXT}}/agent-chain.ts -e {{EXT}}/damage-control.ts -e {{EXT}}/cortex-mcp.ts

# ── Stack completo + modelo específico ───────────────────────────────────
cortex-fast:
    pi --model anthropic/claude-sonnet-4-20250514 -e {{EXT}}/system-select.ts -e {{EXT}}/agent-chain.ts -e {{EXT}}/damage-control.ts -e {{EXT}}/cortex-mcp.ts

# ── Solo pipeline + seguridad (sin selector de agente) ───────────────────
cortex-chain:
    pi -e {{EXT}}/agent-chain.ts -e {{EXT}}/damage-control.ts -e {{EXT}}/cortex-mcp.ts

# ── Solo selector + MCP ───────────────────────────────────────────────────
cortex-select:
    pi -e {{EXT}}/system-select.ts -e {{EXT}}/cortex-mcp.ts

# ── Pipeline rápido: lanza directamente el chain sddwork ─────────────────
sddwork task="":
    pi -e {{EXT}}/agent-chain.ts -e {{EXT}}/damage-control.ts -e {{EXT}}/cortex-mcp.ts "{{task}}"

# ── Pipeline rápido: hotfix ───────────────────────────────────────────────
hotfix task="":
    pi -e {{EXT}}/agent-chain.ts -e {{EXT}}/damage-control.ts -e {{EXT}}/cortex-mcp.ts "{{task}}"

# ── Solo Cortex tools (sin pipeline ni selector) ─────────────────────────
tools:
    pi -e {{EXT}}/cortex-mcp.ts
