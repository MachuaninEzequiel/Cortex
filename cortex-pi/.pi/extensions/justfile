# Cortex Pi — Justfile
# Carga automáticamente el .env si existe en el directorio actual.
# Uso: just <recipe>
#
# Requiere: just, pi v0.70+
# Instalar just: https://just.systems/  (o: winget install Casey.Just)

set dotenv-load := true
set shell := ["powershell", "-Command"]

EXT := ".pi/extensions"

# ── Listado de recipes ────────────────────────────────────────────────────
# Muestra todos los comandos disponibles
default:
    @just --list

# ── Pi base ───────────────────────────────────────────────────────────────
# Pi sin extensiones adicionales (usa solo lo que carga settings.json)
pi:
    pi

# ── Selector de agente (/system) ─────────────────────────────────────────
# Permite cambiar el system prompt al persona de cualquier agente Cortex
system-select:
    pi -e {{EXT}}/system-select.ts

# ── Pipeline de agentes (/chain) ─────────────────────────────────────────
# Ejecuta pipelines secuenciales definidos en agent-chain.yaml
agent-chain:
    pi -e {{EXT}}/agent-chain.ts

# ── Damage control (seguridad) ───────────────────────────────────────────
# Intercepta comandos bash peligrosos según damage-control-rules.yaml
damage-control:
    pi -e {{EXT}}/damage-control.ts

# ── Stack completo Cortex ─────────────────────────────────────────────────
# Las tres extensiones juntas: selector + pipeline + seguridad
cortex:
    pi -e {{EXT}}/system-select.ts -e {{EXT}}/agent-chain.ts -e {{EXT}}/damage-control.ts

# ── Stack completo + modelo específico ───────────────────────────────────
# Útil para usar Gemini Flash en pipelines largos (más barato)
cortex-fast:
    pi --model anthropic/claude-sonnet-4-20250514 -e {{EXT}}/system-select.ts -e {{EXT}}/agent-chain.ts -e {{EXT}}/damage-control.ts

# ── Solo pipeline + seguridad (sin selector de agente) ───────────────────
cortex-chain:
    pi -e {{EXT}}/agent-chain.ts -e {{EXT}}/damage-control.ts

# ── Solo selector de agente + seguridad ──────────────────────────────────
cortex-select:
    pi -e {{EXT}}/system-select.ts -e {{EXT}}/damage-control.ts

# ── Pipeline rápido: lanza directamente el chain sddwork ─────────────────
sddwork task="":
    pi -e {{EXT}}/agent-chain.ts -e {{EXT}}/damage-control.ts "{{task}}"

# ── Pipeline rápido: hotfix ───────────────────────────────────────────────
hotfix task="":
    pi -e {{EXT}}/agent-chain.ts -e {{EXT}}/damage-control.ts "{{task}}"
